{
  "name": "chainsmith",
  "version": "1.0.0",
  "description": "Client-side TLS certificate chain auditor and bundle fixer with a thin Cloudflare Worker relay for issuer (AIA/CRL/OCSP) fetches",
  "type": "module",
  "scripts": {
    "build": "node build.mjs",
    "dev": "node build.mjs && wrangler dev",
    "deploy": "node build.mjs && wrangler deploy",
    "test": "node test.mjs"
  },
  "dependencies": {
    "asn1js": "^3.0.10",
    "pkijs": "^3.4.0"
  },
  "devDependencies": {
    "esbuild": "^0.28.1",
    "wrangler": "^4.100.0"
  }
}
